{
  "_comment": "复制为 ~/.mcp.json 并修改路径。不需要的服务直接删除对应条目。",
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "你的项目目录", "你的桌面目录"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "postgresql://postgres:${PGPASSWORD}@localhost:5432/你的数据库名"]
    },
    "duckduckgo": {
      "command": "npx",
      "args": ["-y", "duckduckgo-mcp-server"]
    },
    "mcp-vision": {
      "command": "uvx",
      "args": ["mcp-vision"]
    },
    "parallel-search": {
      "type": "http",
      "url": "https://search.parallel.ai/mcp",
      "_comment": "免 Key 的 LLM 优化搜索引擎，一次调用返回带引用的摘要"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "_comment": "结构化思维链推理，适合复杂问题的分步分析"
    },
    "squish": {
      "command": "npx",
      "args": ["-y", "squish-memory"],
      "_comment": "本地持久化记忆（SQLite），跨会话自动捕获上下文，1-20ms 召回"
    }
  }
}
