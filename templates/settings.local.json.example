{
  "_comment": "复制为 ~/.claude/settings.local.json。这是本地权限配置，列入 .gitignore，不要提交到 Git。",
  "_comment_defaultMode": "bypassPermissions = 完全跳过权限确认（适合了解 Claude Code 的用户）。如果不想要这个行为，改为 \"default\" 或删除此行。新手建议先不加这行，用一段时间再决定。",
  "_comment_tools": "以下权限列表是推荐配置。如果某个工具你的系统上没有，直接删掉对应行。自己常用的工具路径也加进来。",
  "_comment_security": "⚠️ bypassPermissions 模式下所有操作自动批准。确保你的项目目录干净，没有恶意脚本。",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(date *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(pwd *)",
      "Bash(export *)",
      "Bash(source *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(set *)",
      "Bash(mkdir *)",
      "Bash(rm *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)",
      "Bash(sed *)",
      "Bash(iconv *)",
      "Bash(perl *)",
      "Bash(unzip *)",
      "Bash(curl *)",
      "Bash(reg *)",
      "Bash(netstat *)",
      "Bash(setx *)",
      "Bash(winget *)",
      "Bash(cmd.exe *)",
      "Bash(powershell *)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(cargo *)",
      "Bash(conda *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(rtk *)",
      "Bash(uvx *)",
      "Bash(where *)",
      "Bash(gh *)",
      "Bash(nvidia-smi *)",
      "Bash(wmic *)",
      "Bash(systeminfo)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Agent(*)",
      "Skill(*)",
      "Task(*)",
      "NotebookEdit(*)",
      "Read(//c/**)",
      "Read(//tmp/**)",
      "mcp__filesystem__*",
      "mcp__github__*",
      "mcp__playwright__*",
      "mcp__duckduckgo__*",
      "mcp__mcp-vision__*",
      "mcp__context7__*",
      "mcp__postgres__*",
      "mcp__squish__*",
      "mcp__parallel-search__*",
      "mcp__sequential-thinking__*"
    ]
  },
  "_comment_mcp": "以下是启用的 MCP 服务器列表。这些需要在 ~/.mcp.json 或项目级 .claude.json 中配置对应的服务器信息。不需要的直接删除。",
  "enabledMcpjsonServers": [
    "playwright",
    "filesystem",
    "github",
    "postgres",
    "context7",
    "duckduckgo",
    "mcp-vision",
    "parallel-search",
    "sequential-thinking",
    "squish"
  ]
}
