{
  "_comment": "复制为 ~/.claude/settings.local.json。这是本地权限配置，列入 .gitignore，不要提交到 Git。",
  "permissions": {
    "allow": [
      "WebFetch(domain:chat.deepseek.com)",
      "Bash(pip install *)",
      "Bash(python3 -c ' *)",
      "Bash(python *)",
      "Bash(pip list *)",
      "Bash(perl *)",
      "Bash(cmd.exe *)",
      "Bash(node *)",
      "Bash(pwd -P)",
      "Bash(powershell *)",
      "Bash(curl *)",
      "Bash(pip3 install *)",
      "Bash(npm list *)",
      "Bash(npm install *)",
      "Bash(python3 *)",
      "Bash(where python *)",
      "Bash(where python3 *)",
      "Bash(reg query *)",
      "WebSearch",
      "WebFetch",
      "Bash(npm --version)",
      "Bash(npm search *)",
      "Bash(npx @playwright/mcp --help)",
      "Bash(npx @modelcontextprotocol/server-filesystem --help)",
      "Bash(npx @modelcontextprotocol/server-github --help)",
      "Bash(npx @modelcontextprotocol/server-postgres --help)",
      "Bash(npm prefix *)",
      "Bash(npm bin *)",
      "Bash(npx playwright *)",
      "Bash(gh auth *)",
      "Bash(psql --version)",
      "Bash(netstat -ano)",
      "Bash(ogrinfo *)",
      "Bash(mkdir -p *)",
      "Bash(rm -f *)",
      "Bash(rtk ls *)",
      "Bash(rtk read *)",
      "Bash(rtk --version)",
      "Bash(rtk grep *)",
      "Bash(cargo --version)",
      "Bash(winget install *)",
      "Bash(where gh *)",
      "mcp__filesystem__*",
      "mcp__duckduckgo__*",
      "mcp__vision__*",
      "mcp__playwright__browser_navigate",
      "mcp__github__search_repositories"
    ]
  },
  "enabledMcpjsonServers": [
    "playwright",
    "filesystem",
    "github",
    "postgres",
    "context7",
    "duckduckgo",
    "mcp-vision"
  ]
